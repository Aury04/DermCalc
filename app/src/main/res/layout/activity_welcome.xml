<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="32dp"
    android:background="?android:attr/windowBackground">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@mipmap/ic_launcher"
        android:layout_marginBottom="24dp"
        android:contentDescription="Logo DermCalc" />

    <TextView
        android:id="@+id/tv_titolo_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Benvenuto su DermCalc"
        android:textSize="32sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:textColor="@android:color/holo_blue_dark"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_sottotitolo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="La tua app dermatologica"
        android:textSize="18sp"
        android:fontFamily="sans-serif-light"
        android:textColor="@android:color/darker_gray"
        android:gravity="center"
        android:layout_marginBottom="64dp" />

    <Button
        android:id="@+id/btn_ospite"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Continua come ospite"
        android:background="@drawable/bg_button_rounded"
        android:backgroundTint="#87CEEB"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:textAllCaps="false"/>

    <Button
        android:id="@+id/btn_login"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Login o Registrati"
        android:background="@drawable/bg_button_rounded"
        android:backgroundTint="#4682B4"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textAllCaps="false" />

</LinearLayout>