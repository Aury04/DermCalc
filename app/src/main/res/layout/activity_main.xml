<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DermCalc"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:textColor="@android:color/holo_blue_dark" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleziona un calcolatore clinico:"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_pasi"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="PASI (Psoriasi)"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_easi"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="EASI (Dermatite Atopica)"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_bmi"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="BMI (Indice Massa Corporea)"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_bsa"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="BSA (Superficie Corporea)"
        android:layout_marginBottom="12dp" />

</LinearLayout>