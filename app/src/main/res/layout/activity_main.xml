<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="DermCalc"
        android:textSize="28sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:textColor="@android:color/holo_blue_dark" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Seleziona un calcolatore clinico:"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_pasi"
        android:layout_width="match_parent"
        android:layout_height="65dp"
            android:text="Calcola PASI (Psoriasi)"
        android:drawableLeft="@drawable/icon_pasi" android:drawablePadding="12dp"        android:paddingLeft="16dp"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_easi"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="Calcola EASI (Dermatite Atopica)"
        android:drawableLeft="@drawable/icon_easi" android:drawablePadding="12dp"        android:paddingLeft="16dp"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_bmi"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="Calcola BMI (Indice Massa Corporea)"
        android:drawableLeft="@drawable/icon_bmi" android:drawablePadding="12dp"        android:paddingLeft="16dp"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_bsa"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:text="Calcola BSA (Superfice Corporea)"
        android:drawableLeft="@drawable/icon_bsa" android:drawablePadding="12dp"        android:paddingLeft="16dp"
        android:textColor="@android:color/white"
        android:layout_marginBottom="16dp" />

</LinearLayout>